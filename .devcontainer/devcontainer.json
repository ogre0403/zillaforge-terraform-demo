{
	"name": "golang",
  	"image": "Zillaforge/terraform:0.0.1-alpha",
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.Go",
				"GitHub.copilot-chat",
				"isudox.vscode-jetbrains-keybindings",
				"Arjun.swagger-viewer",
				"humao.rest-client",
				"pjmiravalle.terraform-advanced-syntax-highlighting"
			]
		}
	}
}